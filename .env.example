# =============================================================================
# Content Management Dashboard, environment template
# Copy to .env and fill in. This ONE root .env configures everything: the Next
# app loads it (existing process env wins) and the root db:* / tsx scripts inject
# it via dotenv-cli. There are NO per-app .env files.
#
# It works untouched in keyless local mode: no AI key (composition falls back to
# a deterministic stub) and no auth (NEXT_PUBLIC_DISABLE_AUTH=true). Fill in the
# sections below to take it live. In production these values live as service
# variables (e.g. Railway), not a committed file.
#
# Sections: Brand, Database, Auth, AI, Carousel & generation, TikTok,
# Postiz & n8n, Deploy (optional self-hosted services).
# =============================================================================

# -----------------------------------------------------------------------------
# BRAND
# -----------------------------------------------------------------------------
# Configurable brand identity, consumed by @cmd/brand (the single source of
# truth for the carousel renderer AND the AI composer). Every var below is
# OPTIONAL: unset falls back to the neutral placeholder default shown, so a
# fresh clone renders and composes out of the box. Set these to your real
# handles/links/colors for a live deployment.
#
# Identity (stamped on slides, used in composer + reply prompts, CTAs):
BRAND_HANDLE="@yourhandle"                              # default: @yourhandle
BRAND_DISPLAY_NAME="Your Brand"                         # default: Your Brand
BRAND_TIKTOK_URL="https://www.tiktok.com/@yourhandle"   # default: https://www.tiktok.com/@yourhandle
# X/Twitter is a SEPARATE account. Renders/threads for X are stamped with these,
# not the TikTok handle, so they never point followers to a handle that does not
# exist on that platform.
BRAND_X_HANDLE="@yourhandle"                            # default: @yourhandle
BRAND_X_URL="https://x.com/yourhandle"                  # default: https://x.com/yourhandle
# Link-in-bio hub where every resource/keyword CTA resolves, plus the chip label.
BRAND_CTA_URL="https://example.com/links"               # default: https://example.com/links
BRAND_CTA_LABEL="Link in bio"                           # default: Link in bio
BRAND_TAGLINE="Your tagline here"                       # default: Your tagline here
#
# Client mirror: AppShell's sidebar wordmark is a client component and cannot read
# the server-only BRAND_DISPLAY_NAME above, so set this NEXT_PUBLIC_ mirror to the
# same value for the dashboard chrome. Falls back to "Your Brand" if unset.
NEXT_PUBLIC_BRAND_DISPLAY_NAME="Your Brand"             # default: Your Brand
#
# Accent colors (hex). Only the 3 main accents are overridable; the rest of the
# palette (backgrounds/text ramps) is a fixed neutral warm scheme. Defaults are
# the kit's original orange scheme and look good as-is.
BRAND_PRIMARY_COLOR="#ff7a1a"                           # default: #ff7a1a
BRAND_SECONDARY_COLOR="#f2e9dc"                         # default: #f2e9dc
BRAND_ACCENT_COLOR="#ffb066"                            # default: #ffb066
#
# Composer persona (voice). Override to retune the AI copywriter for a different
# niche; the slide-structure rules stay fixed. Default = AI-tools creator.
BRAND_VOICE_PERSONA=""                                  # default: built-in AI-tools-creator persona

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Postgres for the control-plane DB (the spine; separate from Postiz's own DB).
# This default matches infra/dev/docker-compose.yml exactly (user app, password
# app, db content_dashboard, host port 55433), so `pnpm db:up` + this URL work
# together with no edits.
DATABASE_URL="postgresql://app:app@localhost:55433/content_dashboard?schema=public"

# -----------------------------------------------------------------------------
# AUTH (Clerk)
# -----------------------------------------------------------------------------
# Team auth is Clerk. Pages redirect to /sign-in; APIs return 401 unless a Clerk
# session OR the x-cmd-signature service token (CONTROL_PLANE_API_TOKEN) is
# presented. REQUIRED in any deployed environment (see the warning below).
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
#
# Local-dev escape hatch: skip Clerk entirely and browse the dashboard with no
# auth. WARNING: never set this to "true" in a deployed environment. The
# dashboard has no other gate in front of it, so a deployed instance with auth
# disabled is open to anyone. Set the Clerk keys above and remove (or set to
# "false") this flag before you deploy.
NEXT_PUBLIC_DISABLE_AUTH="true"

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------
# Provider chain for the orchestrator planner and the carousel composer:
# OPENROUTER_API_KEY (preferred) -> ANTHROPIC_API_KEY -> deterministic stub.
# With no key set, slide copy comes from a deterministic stub and the pipeline
# still runs end to end.
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
ORCHESTRATOR_MODEL="anthropic/claude-sonnet-5"
# Direct Anthropic key, used when OPENROUTER_API_KEY is unset. Not needed if
# OpenRouter is configured.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# -----------------------------------------------------------------------------
# CAROUSEL & GENERATION
# -----------------------------------------------------------------------------
# Rendered slide JPEGs are written here and served at /carousels/... for preview
# (default: apps/control-plane/public/carousels).
CAROUSEL_PUBLIC_DIR=""
# Serverless hosts (Vercel) have a read-only filesystem at runtime, so rendered
# slides cannot be written to CAROUSEL_PUBLIC_DIR there. Add a Vercel Blob store
# to the project (Storage tab) and its token here; storage then switches to Blob
# automatically (public, durable URLs) instead of local disk. Leave unset for
# local dev or a host with a persistent volume (e.g. Railway).
BLOB_READ_WRITE_TOKEN=""
# Approved carousels are exported as ready-to-post bundles here (slides plus
# caption.txt). Point this at an iCloud/Drive-synced folder to post from phone.
# Local-machine convenience only: on serverless hosts, use the .zip download on
# the content item instead (works regardless of BLOB_READ_WRITE_TOKEN).
# Default: <cwd>/output/tiktok
CAROUSEL_STAGING_DIR=""
# Default slide count when a brief does not specify one (clamped 3 to 8).
CAROUSEL_DEFAULT_SLIDES="5"
# Output resolution multiplier. Default 1 gives 1080x1920 JPEG, the size + format
# TikTok's photo API accepts (max 1080p, JPEG/WebP only, not PNG). Do not raise
# this for TikTok; larger images are rejected.
CAROUSEL_RENDER_SCALE="1"
# Master switch for API auto-publish (Postiz/TikTok photo posts). Off by default:
# approved carousels are STAGED for manual posting until the TikTok photo-post
# path is validated. Set "true" only once that is wired and approved.
AUTO_PUBLISH="false"
# Optional: URL of your premium template store. When set, the dashboard's style
# picker shows a "More styles" link pointing here. Leave unset to hide it.
# NEXT_PUBLIC_TEMPLATES_STORE_URL=""
# Optional GitHub token. A slide can carry a `repo: "owner/name"` shorthand that
# is expanded into a live GitHub card on the slide. This token only raises the
# GitHub API rate limit for that fetch; leave empty if you do not use repo cards.
GITHUB_TOKEN=""
# Optional external generation engines (unset falls back to the in-process stub).
# HTTP services exposing /generate + /health. HIGGSFIELD supplies AI slide
# backgrounds; without it, slides use the brand gradient.
CLIPPER_API_URL=""
CLIPPER_API_KEY=""
HIGGSFIELD_API_URL=""
HIGGSFIELD_API_KEY=""

# -----------------------------------------------------------------------------
# TIKTOK (Content Posting API, draft/inbox mode)
# -----------------------------------------------------------------------------
# Push approved carousels straight to your TikTok drafts; you tap Post in the app
# (no app audit needed). Setup: docs/tiktok-auto-post.md
# From your TikTok for Developers app (Login Kit + Content Posting API, scope
# video.upload):
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
# Must EXACTLY match a redirect URI registered in the TikTok app:
TIKTOK_REDIRECT_URI="https://your-domain.com/api/tiktok/callback"
# Public HTTPS base where rendered slides are reachable (TikTok fetches them via
# PULL_FROM_URL, so localhost will not work). The domain must be URL-verified in
# the TikTok developer portal. Slides resolve to <PUBLIC_BASE_URL>/carousels/<id>/...
PUBLIC_BASE_URL="https://your-domain.com"

# -----------------------------------------------------------------------------
# POSTIZ & N8N (optional multi-platform publishing, from the control plane)
# -----------------------------------------------------------------------------
# Postiz publishes carousels to your connected channels (e.g. TikTok). Use the
# CLOUD base for a postiz.com account, or your self-hosted instance's URL. The
# client appends /public/v1. Get the key from Postiz -> Settings -> API.
POSTIZ_API_URL="https://api.postiz.com"     # self-hosted: https://<your-postiz>
POSTIZ_API_KEY=""
# REQUIRED if this Postiz account has channels for more than one brand. When
# multiple brands share one account, publishing an item with no explicit
# payload.integrationIds resolves to ITS brand's channels via
# POSTIZ_CHANNELS_<BRAND> below, never to "every connected channel." An item
# whose brand has nothing configured here fails loudly instead of guessing, so
# one brand's content can never land on another brand's accounts.
# Comma-separated Postiz channel ids, per brand (this fork ships a single
# "default" brand surface, see packages/db/prisma/schema.prisma):
POSTIZ_CHANNELS_DEFAULT=""
# Legacy global fallback (only used if the brand-specific var above is unset).
# Applies to EVERY brand alike, so it is unsafe to set on a shared account;
# prefer POSTIZ_CHANNELS_<BRAND>. Never falls back further to "all connected
# channels": leave both unset and publishing refuses with a clear error rather
# than picking wrong.
POSTIZ_DEFAULT_INTEGRATION_IDS=""
# Postiz Cloud strips links from X posts (STRIP_LINKS_FROM_X_POSTS). Leave "true"
# so the engine does not emit dangling link-only replies on X. Set "false" when
# self-hosting Postiz with link-stripping OFF so article links post on X.
POSTIZ_STRIPS_X_LINKS="true"
# The control plane's own URL, so Postiz's media upload can fetch the rendered
# slides (served at /carousels/...). Set to your deployed URL in production.
APP_BASE_URL="http://localhost:3001"
# Public base for resource articles (/r/<slug>), used in generated comment
# replies. Defaults to APP_BASE_URL, then http://localhost:3001. Point this at
# wherever this control-plane app (which serves /r) is actually deployed.
RESOURCE_BASE_URL=""
# n8n webhook base the control plane drains OutboxEvents to.
N8N_WEBHOOK_BASE_URL="http://localhost:5678/webhook"
# Shared secret n8n uses to authenticate calls back into the control plane
# (presented as the x-cmd-signature service token).
CONTROL_PLANE_API_TOKEN="change-me-long-random-string"

# -----------------------------------------------------------------------------
# DEPLOY: self-hosted Postiz + n8n services (optional)
# -----------------------------------------------------------------------------
# These vars are consumed by the Postiz app and n8n THEMSELVES, not by this repo.
# They are here as reference for a self-hosted deploy. See docs/deployment.md.
# Pin the Postiz image ghcr.io/gitroomhq/postiz-app:v2.11.3 (lean, no Temporal).
#
# --- Postiz service ---
# POSTIZ_DATABASE_URL="postgresql://...:5432/postiz"   # Postiz's OWN db, not ours
# REDIS_URL="redis://localhost:6379"
# JWT_SECRET="long-random-string"
# FRONTEND_URL="https://post.your-domain.com"
# NEXT_PUBLIC_BACKEND_URL="https://post.your-domain.com/api"
# BACKEND_INTERNAL_URL="http://postiz.railway.internal:3000"
# DISABLE_REGISTRATION="true"        # set AFTER creating the admin account
# STORAGE_PROVIDER="local"
# UPLOAD_DIRECTORY="/uploads"
#
# --- Postiz per-platform OAuth apps (register each, paste keys) ---
# X_API_KEY=""
# X_API_SECRET=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""
# FACEBOOK_APP_ID=""
# FACEBOOK_APP_SECRET=""
# YOUTUBE_CLIENT_ID=""
# YOUTUBE_CLIENT_SECRET=""
# TIKTOK_CLIENT_ID=""
# TIKTOK_CLIENT_SECRET=""
#
# --- n8n service ---
# N8N_ENCRYPTION_KEY="long-random-string"
# N8N_HOST="flows.your-domain.com"
# WEBHOOK_URL="https://flows.your-domain.com/"
