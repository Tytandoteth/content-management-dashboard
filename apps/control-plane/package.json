{
  "name": "@cmd/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose -f ../../infra/dev/docker-compose.yml up -d",
    "predev": "docker compose -f ../../infra/dev/docker-compose.yml up -d 2>/dev/null || echo '⚠ Dev DB not started — is Docker Desktop running? (your data is safe in the control_plane_pgdata volume)'",
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@clerk/nextjs": "7.5.1",
    "@cmd/brand": "workspace:*",
    "@cmd/carousel-render": "workspace:*",
    "@cmd/contracts": "workspace:*",
    "@cmd/db": "workspace:*",
    "@cmd/generation": "workspace:*",
    "@cmd/integrations": "workspace:*",
    "@cmd/orchestrator": "workspace:*",
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "0.12.2",
    "@prisma/client": "^6.1.0",
    "@vercel/blob": "2.4.1",
    "dotenv": "17.4.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
